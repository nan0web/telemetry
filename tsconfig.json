{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"allowJs": true,
		"checkJs": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"declarationDir": "./types",
		"strict": true,
		"noEmit": false,
		"skipLibCheck": true,
		"outDir": "./types"
	},
	"include": ["src/**/*.js"],
	"exclude": ["src/**/*.test.js", "src/README.md.js", "node_modules"]
}
